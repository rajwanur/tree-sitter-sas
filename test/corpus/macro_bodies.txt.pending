================================================================================
Nested macro definition + call (G-03 Phase 1)
================================================================================
%macro outer(indata=);
  %macro inner(flag);
    %put flag is &flag;
  %mend inner;

  %inner(Y);
%mend outer;
--------------------------------------------------------------------------------



